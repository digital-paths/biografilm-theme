{% extends "base.twig" %}

{% block hero %}
  {{
    include(
      "components/hero/hero.twig",
      { hero_title: "News", hero_title_style: "primary" }
    )
  }}
{% endblock hero %}

{% block content %}
  <div
    x-data="{ drawerOpen: false }"
    x-effect="document.body.style.overflow = drawerOpen ? 'hidden' : ''"
    @keydown.escape.window="drawerOpen = false"
  >
    <div id="filters-sentinel" class="h-0"></div>
    <div data-sticky-top class="top-0 z-50 mb-20">
      <div class="filters-black flex w-full justify-between bg-black">
        {# Mobile: filter icon #}
        <button
          type="button"
          class="border-stroke hover:bg-white-hover active:bg-white-active relative flex shrink-0 cursor-pointer items-center justify-center border-r bg-white px-6 text-black transition-colors focus-visible:z-10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-black lg:hidden"
          @click="drawerOpen = true"
          aria-label="{{ function('pll__', 'Apri filtri') }}"
        >
          {{ include("icons/generic/filters.svg")|attr({ class: "size-5" }) }}
          <span class="filters-active-dot bg-red absolute top-2 right-2 hidden size-2 rounded-full"></span>
        </button>
        {# Desktop: categories filter #}
        <div class="hidden lg:block lg:min-w-1/3">
          {{ function("do_shortcode", '[facetwp facet="categories_news"]') }}
        </div>
        <button
          type="button"
          class="text-tight border-stroke hover:bg-white-hover active:bg-white-active -ml-px cursor-pointer border bg-white px-4 py-3 text-base text-black uppercase transition-colors"
          onclick="FWP.reset()"
        >
          Reset
        </button>
      </div>
    </div>

    {% include "parts/filters-drawer.twig" with {
      state_var: "drawerOpen",
      facets: ["categories_news"]
    } %}
  </div>

  <section class="w-full">
    <div
      class="border-stroke 3xl:grid-cols-4 grid w-full grid-cols-1 md:grid-cols-2 xl:grid-cols-3"
    >
      {% for post in posts %}
        {{
          include(
            "parts/cards/news-card.twig",
            { news: post, extra_class: loop.last ? "" : "" }
          )
        }}
      {% else %}
        <p
          class="text-tight col-span-full py-30 text-center text-xl font-semibold text-black"
        >
          {{ function("pll__", "Nessuna news trovata.") }}
        </p>
      {% endfor %}

      {# 2-col fillers #}
      {% set count = posts|length %}
      {% if count % 2 == 1 %}
        <div class="border-stroke col-span-1 border-l xl:hidden"></div>
      {% endif %}

      {# 3-col fillers #}
      {% if count % 3 == 1 %}
        <div class="border-stroke 3xl:hidden col-span-1 hidden border-l xl:block"></div>
        <div class="3xl:hidden col-span-1 hidden xl:block"></div>
      {% elseif count % 3 == 2 %}
        <div class="border-stroke 3xl:hidden col-span-1 hidden border-l xl:block"></div>
      {% endif %}

      {# 4-col fillers #}
      {% if count % 4 == 1 %}
        <div class="border-stroke 3xl:block col-span-1 hidden border-l"></div>
        <div class="3xl:block col-span-1 hidden"></div>
        <div class="3xl:block col-span-1 hidden"></div>
      {% elseif count % 4 == 2 %}
        <div class="border-stroke 3xl:block col-span-1 hidden border-l"></div>
        <div class="3xl:block col-span-1 hidden"></div>
      {% elseif count % 4 == 3 %}
        <div class="border-stroke 3xl:block col-span-1 hidden border-l"></div>
      {% endif %}
    </div>
  </section>

  {% include "parts/pagination.twig" with {
    pagination: posts.pagination({ show_all: false, mid_size: 3, end_size: 2 })
  } %}
{% endblock content %}
