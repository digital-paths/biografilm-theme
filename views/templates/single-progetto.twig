{% extends "base.twig" %}

{% set progetto = function("get_field", "progetto", post.ID) %}
{% set tipologia =
  function("wp_get_post_terms", post.ID, "tipologia-progetto")
%}
{% set target = function("wp_get_post_terms", post.ID, "target-progetto") %}
{% set status = function("wp_get_post_terms", post.ID, "status-progetto") %}
{% set luogo = function("wp_get_post_terms", post.ID, "luogo-progetto") %}

{% set date_format = {
  anno: "Y",
  anno_mese: "F Y",
  anno_mese_giorno: "d F Y"
}[progetto.precisione_date ?? "anno_mese_giorno"]
  ?? "d F Y"
%}

{% block hero %}
{% endblock hero %}

{% block content %}
  {# Hero image #}
  {% if post.thumbnail %}
    {% set thumb_id = function("get_post_thumbnail_id", post.ID) %}
    {% set fp = thumb_id
      ? function("get_post_meta", thumb_id, "focalpoint", true)
      : null
    %}
    {% set fp_style = fp
      ? "object-position: " ~ ((fp.left * 100)|round) ~ "% "
        ~ ((fp.top * 100)|round)
        ~ "%;"
      : null
    %}
    <div
      class="film-hero relative mt-[108px] h-[400px] w-full overflow-hidden lg:aspect-10/4 lg:h-auto"
    >
      <div
        class="overlay-blur overlay absolute z-30 h-full w-full bg-transparent backdrop-blur-[50px]"
      ></div>
      <img
        src="{{ post.thumbnail.src("full") }}"
        alt="{{ post.title }}"
        class="absolute inset-0 h-full w-full object-cover"
        style="{{ fp_style }}"
      />
    </div>
  {% endif %}

  {# Title + breadcrumbs #}
  <div
    class="w-full px-6 py-20 xl:px-10 {{ not post.thumbnail ? 'mt-[108px]' : '' }}"
  >
    <div class="flex flex-col gap-6">
      {{ include("parts/breadcrumbs.twig") }}
      <h1 class="display-h1-news blur-in">{{ post.title }}</h1>
    </div>
  </div>

  <div class="border-b-stroke mx-auto grid grid-cols-3 border-b">
    {# Tabs — cols 1–2 #}
    <div class="col-span-3 xl:col-span-2">
      {% if progetto.tabs %}
        {{
          include(
            "components/tabs/tabs.twig",
            { component: { tabs: progetto.tabs, full_width: true } }
          )
        }}
      {% endif %}
    </div>

    {# Informazioni — col 3 #}
    <div
      class="border-stroke col-span-3 flex flex-col gap-10 border-t border-l px-6 py-10 xl:col-span-1 xl:p-10"
    >
      <h2 class="heading-h6 font-semibold">{{ function("pll__", "Informazioni") }}</h2>

      {% if progetto.periodo_inizio or progetto.periodo_fine %}
        <div class="flex flex-col gap-2">
          <span class="text-tight text-xl font-semibold text-black">
            {{ function("pll__", "Periodo") }}
          </span>
          <span class="text-tight text-xl">
            {% if progetto.periodo_inizio %}{{
              progetto.periodo_inizio|date(date_format)
            }}{% endif %}
            {% if progetto.periodo_fine %}
              — {{ progetto.periodo_fine|date(date_format) }}
            {% endif %}
          </span>
        </div>
      {% endif %}

      {% if status %}
        <div class="flex flex-col gap-2">
          <span class="text-tight text-xl font-semibold text-black">
            {{ function("pll__", "Status") }}
          </span>
          <span class="text-tight text-xl">
            {{ status|map(t => t.name)|join(" · ") }}
          </span>
        </div>
      {% endif %}

      {% if tipologia %}
        <div class="flex flex-col gap-2">
          <span class="text-tight text-xl font-semibold text-black">
            {{ function("pll__", "Tipologia") }}
          </span>
          <span class="text-tight text-xl">
            {{ tipologia|map(t => t.name)|join(" · ") }}
          </span>
        </div>
      {% endif %}

      {% if target %}
        <div class="flex flex-col gap-2">
          <span class="text-tight text-xl font-semibold text-black">
            {{ function("pll__", "Target") }}
          </span>
          <span class="text-tight text-xl">
            {{ target|map(t => t.name)|join(" · ") }}
          </span>
        </div>
      {% endif %}

      {% if luogo %}
        <div class="flex flex-col gap-2">
          <span class="text-tight text-xl font-semibold text-black">{{ function("pll__", "Luogo") }}</span>
          <span class="text-tight text-xl">
            {{ luogo|map(t => t.name)|join(" · ") }}
          </span>
        </div>
      {% endif %}

      {% if progetto.relatori_tutor %}
        <div class="flex flex-col gap-2">
          <span class="text-tight text-xl font-semibold text-black">
            {{ function("pll__", "Relatori / Tutor") }}
          </span>
          <span class="text-tight text-xl">
            {{ progetto.relatori_tutor|map(r => r.nome)|join(" · ") }}
          </span>
        </div>
      {% endif %}

      {% if progetto.beneficiari %}
        <div class="flex flex-col gap-2">
          <span class="text-tight text-xl font-semibold text-black">
            {{ function("pll__", "Beneficiari") }}
          </span>
          <div class="prose text-tight max-w-none text-xl">
            {{ progetto.beneficiari }}
          </div>
        </div>
      {% endif %}

      {% if progetto.restituzione_finale %}
        <div class="flex flex-col gap-2">
          <span class="text-tight text-xl font-semibold text-black">
            {{ function("pll__", "Restituzione finale") }}
          </span>
          <div class="prose text-tight max-w-none text-xl">
            {{ progetto.restituzione_finale }}
          </div>
        </div>
      {% endif %}

      {% if progetto.links %}
        <div class="mt-auto flex flex-col gap-3">
          {% for item in progetto.links %}
            {% if item.link %}
              {% include "components/button.twig" with {
                as_link: true,
                size: "lg",
                variant: item.stile == "secondary"
                  ? "outline"
                  : item.stile == "link" ? "link" : "default",
                label: item.link.title,
                attributes: {
                  href: item.link.url,
                  target: item.link.target ? : "_self",
                  class: "w-full"
                }
              } %}
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>

  {% set galleria = function("get_field", "galleria", post.ID) %}
  {% if galleria.items %}
    {{
      include(
        "components/media-displayer/media-displayer.twig",
        { component: galleria }
      )
    }}
  {% endif %}

  {% set partners_displayer = function("get_field", "partners_displayer", post.ID) %}
  {% if partners_displayer.items %}
    {{
      include(
        "components/partners-displayer/partners-displayer.twig",
        { component: partners_displayer }
      )
    }}
  {% endif %}

  {% set page_components = function("get_field", "page_components", post.ID) %}
  {% for component in page_components %}
    {% set layout = component.acf_fc_layout|replace({ "_": "-" }) %}
    {{
      include(
        "components/" ~ layout ~ "/" ~ layout ~ ".twig",
        { component: component }
      )
    }}
  {% endfor %}

  {% include "parts/cta-bottom.twig" with {
    cta_title: function("get_field", "progetti_cta_titolo", "option"),
    cta_desc: function("get_field", "progetti_cta_descrizione", "option"),
    cta_link: function("get_field", "progetti_cta_link", "option")
  } %}
{% endblock content %}
