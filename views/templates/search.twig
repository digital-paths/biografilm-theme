{% extends "base.twig" %}

{% block hero %}
  {{
    include(
      "components/hero/hero.twig",
      {
        hero_title: function("pll__", "Risultati"),
        hero_title_style: "primary",
        hero_subtitle: found_posts ~ " " ~ function("pll__", "risultati trovati per la ricerca") ~ " \"" ~ search_query ~ "\""
      }
    )
  }}
{% endblock hero %}

{% block content %}
  <div
    x-data="{ drawerOpen: false }"
    x-effect="document.body.style.overflow = drawerOpen ? 'hidden' : ''"
    @keydown.escape.window="drawerOpen = false"
  >
    <div id="filters-sentinel" class="h-0"></div>
    <div data-sticky-top class="top-0 z-50 mb-20">
      <div class="filters-black flex w-full justify-between bg-black">
        {# Mobile: filter icon #}
        <button
          type="button"
          class="border-stroke hover:bg-white-hover active:bg-white-active relative flex shrink-0 cursor-pointer items-center justify-center border-r bg-white px-6 text-black transition-colors focus-visible:z-10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-black lg:hidden"
          @click="drawerOpen = true"
          aria-label="{{ function('pll__', 'Apri filtri') }}"
        >
          {{ include("icons/generic/filters.svg")|attr({ class: "size-5" }) }}
          <span class="filters-active-dot bg-red absolute top-2 right-2 hidden size-2 rounded-full"></span>
        </button>
        {# Desktop: result_type filter #}
        <div class="hidden lg:block lg:min-w-1/3">
          {{ function("do_shortcode", '[facetwp facet="result_type"]') }}
        </div>
        <button
          type="button"
          class="text-tight border-stroke hover:bg-white-hover active:bg-white-active -ml-px cursor-pointer border bg-white px-4 py-3 text-base text-black uppercase transition-colors"
          onclick="FWP.reset()"
        >
          Reset
        </button>
      </div>
    </div>

    {% include "parts/filters-drawer.twig" with {
      state_var: "drawerOpen",
      facets: ["result_type"]
    } %}
  </div>

  <section class="w-full pb-20">
    <div class="facetwp-template">
    {% if posts %}
      <div class="border-stroke flex w-full flex-col border-t">
        {% for post in posts %}
          {% set thumb_id = function("get_post_thumbnail_id", post.ID) %}
          {% set image_url = thumb_id
            ? function("get_the_post_thumbnail_url", post.ID, "large")
            : ""
          %}
          {% set fp = thumb_id
            ? function("get_post_meta", thumb_id, "focalpoint", true)
            : null
          %}
          {% set fp_style = fp
            ? "object-position: " ~ ((fp.left * 100)|round) ~ "% "
              ~ ((fp.top * 100)|round)
              ~ "%;"
            : null
          %}

          <div
            class="border-b-stroke group relative flex flex-col border-b transition-colors duration-[1500ms] ease-in-out hover:bg-gray-200 hover:duration-700 lg:flex-row lg:items-end lg:border-b-0"
          >
            <a
              href="{{ post.link }}"
              class="absolute inset-0 z-10 transition-colors duration-300"
              aria-label="{{ post.title }}"
            >

            </a>

            <div
              class="pointer-events-none relative flex min-w-0 flex-1 flex-col lg:flex-row"
            >
              <div
                class="bg-red relative aspect-video w-full shrink-0 overflow-hidden lg:aspect-auto lg:w-65"
              >
                <div
                  class="overlay absolute z-30 h-full w-full bg-transparent [mask-image:radial-gradient(ellipse_at_center,transparent_45%,black_90%)] backdrop-blur-[0px] transition-[backdrop-filter,_-webkit-backdrop-filter] duration-[1500ms] ease-in-out [-webkit-mask-image:radial-gradient(ellipse_at_center,transparent_45%,black_90%)] group-hover:backdrop-blur-[90px] group-hover:duration-700"
                ></div>
                <img
                  src="{{
                  image_url
                    ?
                    : function("get_stylesheet_directory_uri")
                      ~ "/assets/images/fallback-img-red.jpg"
                  }}"
                  alt="{{ post.title }}"
                  class="absolute inset-0 h-full w-full {{
                  image_url
                    ? "object-cover"
                    : "object-contain object-center lg:inset-auto lg:top-1/2 lg:left-1/2 lg:h-auto lg:w-full lg:-translate-x-1/2 lg:-translate-y-1/2"
                  }}"
                  {{ image_url ? 'style="' ~ fp_style ~ '"' }}
                />
              </div>

              <div
                class="lg:border-b-stroke flex flex-1 flex-col justify-between gap-8 px-6 py-10 lg:border-b lg:px-8 lg:py-6"
              >
                <div class="flex flex-col gap-3">
                  {% if post.title %}
                    <h5 class="text-tight text-2xl! font-semibold">
                      {{ post.title }}
                    </h5>
                  {% endif %}
                  {% if post.post_type %}
                    {% set post_type_label = {
                      "page": function("pll__", "Pagina"),
                      "post": function("pll__", "Post"),
                      "film": function("pll__", "Film"),
                      "evento": function("pll__", "Evento"),
                      "news": function("pll__", "News"),
                      "progetto": function("pll__", "Progetto")
                    }[post.post_type] ?? post.post_type %}
                    <p
                      class="text-tight text-red text-sm font-semibold uppercase"
                    >
                      {{ post_type_label }}
                    </p>
                  {% endif %}
                  {% if post.excerpt %}
                    <p class="text-tight text-base text-black">
                      {{ post.excerpt }}
                    </p>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <p
        class="text-tight border-stroke border-t py-20 text-center text-xl font-semibold text-black"
      >
        {{ function("pll__", "Nessun risultato trovato.") }}
      </p>
    {% endif %}
    </div>{# /.facetwp-template #}
  </section>
{% endblock content %}
