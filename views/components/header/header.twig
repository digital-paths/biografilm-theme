<div
  x-data="{ menuOpen: false, mobileMenuOpen: false, searchOpen: false }"
  class="fixed top-0 z-[40000] flex w-full flex-col transition-transform duration-200 [transition-timing-function:cubic-bezier(0.22,1,0.36,1)]"
>
  <div class="relative">
    <div class="relative flex w-full items-stretch justify-between bg-white">
      <div
        x-show="menuOpen"
        x-cloak
        class="overlay absolute z-30 h-full w-full bg-transparent backdrop-blur-[2px]"
      ></div>
      <!-- Logo and date + mobile search overlay -->
      <div class="relative flex-1 lg:flex-none">
        <!-- Logo and date -->
        <div class="flex items-center justify-start gap-4 px-6 py-4 lg:px-10">
          <a href="{{ home_url }}" class="focusable block">
            {{
              include("views/svgs/logo/logo-biografilm-red.svg")|attr({
                class: "w-[153px] h-auto"
              })
            }}
          </a>
          {% if header_show_date_location %}
            <div
              class="header-dateline text-tight flex flex-col items-start justify-start gap-0 text-xs"
            >
              <span class="font-semibold">{{ header_date }}</span>
              <span class="font-normal">{{ header_location }}</span>
            </div>
          {% endif %}
        </div>
        <!-- Mobile menu open: search + language -->
        <div
          x-show="mobileMenuOpen"
          x-cloak
          x-transition:enter="transition duration-200 ease-out"
          x-transition:enter-start="opacity-0"
          x-transition:enter-end="opacity-100"
          x-transition:leave="transition duration-150 ease-in"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
          class="absolute inset-0 z-10 flex items-stretch bg-white lg:hidden"
        >
        <div class="flex flex-1 items-center px-4">
          {{ function("do_shortcode", '[searchwp_form id=2]') }}
        </div>
        <div
          x-data="{ langOpen: false }"
          class="border-l-stroke relative border-l"
          @click.outside="langOpen = false"
        >
          {% if languages %}
            {% set other_lang = null %}
            {% set current_slug = '' %}
            {% for slug, lang in languages %}
              {% if lang.current_lang %}{% set current_slug = slug %}{% endif %}
              {% if not lang.current_lang %}{% set other_lang = lang %}{% endif %}
            {% endfor %}
            <button
              type="button"
              @click="langOpen = !langOpen"
              class="focusable hover:bg-white-hover active:bg-white-active flex h-full cursor-pointer items-center gap-2 bg-white px-6"
            >
              <span>{{ current_slug|upper }}</span>
              {{
                include("icons/generic/chevron-down.svg")|attr({
                  class: "size-5 transition-transform duration-300",
                  ":class": "langOpen ? 'rotate-180' : ''"
                })
              }}
            </button>
            <div
              x-show="langOpen"
              x-cloak
              x-transition:enter="transition duration-150 ease-out"
              x-transition:enter-start="opacity-0 -translate-y-1"
              x-transition:enter-end="opacity-100 translate-y-0"
              x-transition:leave="transition duration-100 ease-in"
              x-transition:leave-start="opacity-100 translate-y-0"
              x-transition:leave-end="opacity-0 -translate-y-1"
              class="border-stroke absolute top-full left-0 z-50 w-full border bg-white shadow-sm"
            >
              <a
                href="{{ other_lang.url }}"
                class="hover:bg-white-hover active:bg-white-active text-tight flex w-full items-center px-6 py-6 text-base"
                @click="langOpen = false"
              >
                {{ other_lang.slug|upper }}
              </a>
            </div>
          {% else %}
            <a
              href="/"
              class="focusable hover:bg-white-hover active:bg-white-active flex h-full cursor-pointer items-center gap-2 bg-white px-6"
            >
              <span>ITA</span>
              {{
                include("icons/generic/chevron-down.svg")|attr({ class: "size-5" })
              }}
            </a>
          {% endif %}
        </div>
        </div>
      </div>
      <!-- Mobile menu button -->
      <button
        type="button"
        @click="mobileMenuOpen = !mobileMenuOpen"
        class="hover:bg-white-hover active:bg-white-active focusable border-l-stroke relative z-40 flex aspect-square cursor-pointer items-center justify-center border-l bg-white px-5 lg:hidden"
      >
        <span x-show="!mobileMenuOpen">
          {{ include("icons/generic/menu.svg")|attr({ class: "size-5" }) }}
        </span>
        <span x-show="mobileMenuOpen" x-cloak>
          {{ include("icons/generic/close.svg")|attr({ class: "size-5" }) }}
        </span>
      </button>
      <!-- Navigation -->
      <div
        class="border-l-stroke hidden flex-1 items-stretch justify-between border-l lg:flex"
      >
        <!-- Language -->
        <div
          x-data="{ langOpen: false }"
          class="relative"
          @click.outside="langOpen = false"
        >
          {% if languages %}
            {% set other_lang = null %}
            {% set current_slug = "" %}
            {% for slug, lang in languages %}
              {% if lang.current_lang %}{% set current_slug = slug %}{% endif %}
              {% if not lang.current_lang %}{% set other_lang =
                lang
              %}{% endif %}
            {% endfor %}
            <button
              type="button"
              @click="langOpen = !langOpen"
              class="focusable hover:bg-white-hover active:bg-white-active flex cursor-pointer items-center gap-2 bg-white p-6 pr-4!"
            >
              <span>{{ current_slug|upper }}</span>
              {{
                include("icons/generic/chevron-down.svg")|attr({
                  class: "size-5 transition-transform duration-300",
                  ":class": "langOpen ? 'rotate-180' : ''"
                })
              }}
            </button>
            <div
              x-show="langOpen"
              x-cloak
              x-transition:enter="transition duration-150 ease-out"
              x-transition:enter-start="opacity-0 -translate-y-1"
              x-transition:enter-end="opacity-100 translate-y-0"
              x-transition:leave="transition duration-100 ease-in"
              x-transition:leave-start="opacity-100 translate-y-0"
              x-transition:leave-end="opacity-0 -translate-y-1"
              class="border-stroke absolute top-full left-0 z-50 w-full border bg-white shadow-sm"
            >
              <a
                href="{{ other_lang.url }}"
                class="hover:bg-white-hover active:bg-white-active text-tight flex w-full items-center px-6 py-6 text-base"
                @click="langOpen = false"
              >
                {{ other_lang.slug|upper }}
              </a>
            </div>
          {% else %}
            <a
              href="/"
              class="focusable hover:bg-white-hover active:bg-white-active flex cursor-pointer items-center gap-2 bg-white p-6 pr-4!"
            >
              <span>ITA</span>
              {{
                include("icons/generic/chevron-down.svg")|attr({
                  class: "size-5"
                })
              }}
            </a>
          {% endif %}
        </div>
        <!-- Right side -->
        <div class="flex">
          <!-- Tabs -->
          <div class="flex items-stretch">
            <a
              href="{{ nav_urls.festival }}"
              class="text-tight flex items-center p-6 text-base transition-colors {{
              current_section == "festival"
                ? "bg-red font-semibold text-white"
                : "bg-white hover:bg-white-hover active:bg-white-active cursor-pointer text-black"
              }}"
            >
              Festival
            </a>
            <a
              href="{{ nav_urls.industry }}"
              class="text-tight flex items-center p-6 text-base transition-colors {{
              current_section == "industry"
                ? "bg-red font-semibold text-white"
                : "bg-white hover:bg-white-hover active:bg-white-active cursor-pointer text-black"
              }}"
            >
              Industry
            </a>
            <a
              href="{{ nav_urls.campus }}"
              class="text-tight flex items-center p-6 text-base transition-colors {{
              current_section == "campus"
                ? "bg-red font-semibold text-white"
                : "bg-white hover:bg-white-hover active:bg-white-active cursor-pointer text-black"
              }}"
            >
              Campus
            </a>
          </div>
          <!-- Sliding search input -->
          <div
            class="grid transition-[grid-template-columns] duration-300 ease-[cubic-bezier(0.22,1,0.36,1)]"
            :class="searchOpen ? 'grid-cols-[1fr] border-l-stroke border-l' : 'grid-cols-[0fr]'"
          >
            <div class="overflow-hidden">
              <div class="flex h-full items-center px-4">
                {{ function("do_shortcode", "[searchwp_form id=2]") }}
              </div>
            </div>
          </div>
          <!-- Search & Menu -->
          <div class="flex items-stretch">
            <button
              type="button"
              @click="searchOpen = !searchOpen; menuOpen = false"
              class="hover:bg-white-hover active:bg-white-active focusable flex aspect-square cursor-pointer items-center justify-center bg-white p-6"
              :class="searchOpen ? '' : 'border-l-stroke border-l'"
            >
              <span x-show="!searchOpen">
                {{
                  include("icons/generic/search.svg")|attr({ class: "size-5" })
                }}
              </span>
              <span x-show="searchOpen" x-cloak>
                {{
                  include("icons/generic/close.svg")|attr({ class: "size-5" })
                }}
              </span>
            </button>
            <button
              type="button"
              @click="menuOpen = !menuOpen; searchOpen = false"
              class="hover:bg-white-hover active:bg-white-active focusable border-l-stroke relative z-40 flex aspect-square cursor-pointer items-center justify-center border-l bg-white p-6"
            >
              <span x-show="!menuOpen">
                {{
                  include("icons/generic/menu.svg")|attr({ class: "size-5" })
                }}
              </span>
              <span x-show="menuOpen" x-cloak>
                {{
                  include("icons/generic/close.svg")|attr({ class: "size-5" })
                }}
              </span>
            </button>
          </div>
        </div>
      </div>
    </div>
    <!-- HEADER SUBMENU -->
    {{ include("components/header/header-submenu.twig") }}
  </div>
  <!-- MOBILE TABS -->
  {{ include("components/header/header-mobile-tabs.twig") }}
  <!-- MOBILE MENU -->
  {{ include("components/header/header-mobile-menu.twig") }}
  <!-- HEADER NAVIGATION BAR -->
  {{ include("components/header/header-nav-bar.twig") }}
</div>
