<div class="mt-[108px] w-full px-6 py-20 xl:px-10 xl:py-30">
  <div class="flex flex-col gap-6">
    {{ include("parts/breadcrumbs.twig") }}
    {% set title_class = {
      primary: "display-h1-primary",
      secondary: "display-h1-secondary",
      tertiary: "display-h1-tertiary",
      news: "display-h1-news"
    }[hero_title_style ?? "primary"]
      ?? "display-h1-primary"
    %}
    <h1 class="{{ title_class }}">{{ hero_title }}</h1>
    {% if hero_subtitle %}
      <p class="text-tight text-xl text-black/60">{{ hero_subtitle }}</p>
    {% endif %}
  </div>
</div>
