<div class="premi-wrapper w-full">
  <div class="swiper premi-swiper">
    <div class="swiper-wrapper">
      {% for item in items %}
        <div
          class="swiper-slide border-stroke flex! flex-col gap-6! border-b border-l px-6 py-10 xl:px-10 xl:py-20"
        >
          {% if item.titolo %}
            <div class="flex flex-col gap-2">
              {% if item.powered_by %}
                <a
                  href="{{ item.powered_by.url }}"
                  target="{{ item.powered_by.target ? : "_self" }}"
                  class="text-tight text-base"
                >
                  Powered by <span class="text-red hover:text-red-hover active:text-red-active font-semibold underline underline-offset-3">{{
                      item.powered_by.title
                    }}</span>
                </a>
              {% endif %}

              <h3 class="heading-h6 font-semibold">{{ item.titolo }}</h3>
            </div>
          {% endif %}

          {% if item.contenuto %}
            <div class="prose text-base text-black/80 [&_a]:text-red [&_a]:font-semibold [&_a]:underline [&_a]:underline-offset-3 [&_a]:hover:text-red-hover [&_a]:active:text-red-active [&_ul]:list-disc [&_ul]:pl-5 [&_ol]:list-decimal [&_ol]:pl-5 [&_li]:mt-1">
              {{ item.contenuto|raw }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
    {% if (items|length) > 2 %}
      <div class="hero-carousel-nav contents-displayer-nav border-b-0">
        <button class="swiper-button-prev" aria-label="{{ function('pll__', 'Precedente') }}"></button>
        <div class="swiper-pagination"></div>
        <button class="swiper-button-next" aria-label="{{ function('pll__', 'Successivo') }}"></button>
      </div>
    {% endif %}
  </div>
</div>
