<section
  class="w-full {{ component.border_top ? "border-stroke border-t" : "" }} {{
  component.border_bottom
    ? "border-stroke border-b"
    : ""
  }}"
>
  <div class="flex flex-col gap-6 px-6 py-20 xl:px-10 xl:py-30">
    {% if component.heading %}
      <h2 class="heading-h4 blur-in font-semibold xl:w-4/5">
        {{ component.heading }}
      </h2>
    {% endif %}
    {% if component.title %}
      <h6 class="heading-h5 blur-in font-semibold xl:w-4/5">
        {{ component.title }}
      </h6>
    {% endif %}
    {% if component.content %}
      <div class="prose blur-in max-w-none text-xl leading-[150%] xl:w-4/5">
        {{ component.content }}
      </div>
    {% endif %}
    {% if component.links %}
      <div class="mt-10 flex flex-col gap-6">
        {% for item in component.links %}
          {% if item.link %}
            {{
              include(
                "components/button.twig",
                {
                  as_link: true,
                  size: "lg",
                  variant: item.stile == "secondary"
                    ? "outline"
                    : item.stile == "link" ? "link" : "default",
                  label: item.link.title,
                  attributes: {
                    href: item.link.url,
                    target: item.link.target ? : "_self",
                    class: "xl:w-fit w-full"
                  }
                }
              )
            }}
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>
