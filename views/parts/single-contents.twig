{% set doc = function("get_field", "content_doc", post.ID) %}

{% set thumb_id = function("get_post_thumbnail_id", post.ID) %}
{% set fp = thumb_id
  ? function("get_post_meta", thumb_id, "focalpoint", true)
  : null
%}
{% set fp_style = fp
  ? "object-position: " ~ ((fp.left * 100)|round) ~ "% "
    ~ ((fp.top * 100)|round)
    ~ "%;"
  : null
%}
<div class="mt-[108px] flex">
  <div class="w-full px-6 py-20 lg:w-2/3 xl:px-10 xl:py-30">
    <div class="flex flex-col gap-6">
      {{ include("parts/breadcrumbs.twig") }}
      <h1 class="display-h1-secondary blur-in">{{ post.title }}</h1>
      {% if doc.sottotitolo %}
        <p class="heading-h6">
          {{ doc.sottotitolo }}
        </p>
      {% endif %}
    </div>
  </div>
  <div class="hidden w-1/3 flex-1 pt-20 lg:block xl:pt-30">
    <div class="bg-red flex h-full items-center justify-center p-10">
      {% if doc.icon %}
        <img
          src="{{ doc.icon.url }}"
          alt="{{ doc.icon.alt }}"
          class="h-full max-h-[180px] w-auto object-contain"
        />
      {% endif %}
    </div>
  </div>
</div>
{% if doc.tabs or doc.informazioni or doc.links %}
  <div class="border-b-stroke mx-auto grid grid-cols-3 border-b">
    {# Tabs — cols 1–2 #}
    {% if doc.tabs %}
      <div class="col-span-3 xl:col-span-2">
        {{
          include(
            "components/tabs/tabs.twig",
            { component: { tabs: doc.tabs, full_width: true } }
          )
        }}
      </div>
    {% endif %}

    {# Informazioni — col 3 #}
    {% if doc.informazioni or doc.links %}
      <div
        class="border-stroke col-span-3 flex flex-col gap-10 border-t border-l px-6 py-10 xl:col-span-1 xl:p-10"
      >
        <h2 class="heading-h6 font-semibold">{{ function("pll__", "Informazioni utili") }}</h2>

        {% for row in doc.informazioni %}
          <div class="flex flex-col gap-2">
            <span class="text-tight text-xl font-semibold text-black">
              {{ row.label }}
            </span>
            <div class="text-tight prose [&_a]:text-red text-xl">
              {{ row.value }}
            </div>
          </div>
        {% endfor %}

        {% if doc.links %}
          <div class="mt-auto flex flex-col gap-3">
            {% for item in doc.links %}
              {% if item.link %}
                {% include "components/button.twig" with {
                  as_link: true,
                  size: "lg",
                  variant: item.stile == "secondary"
                    ? "outline"
                    : item.stile == "link" ? "link" : "default",
                  label: item.link.title,
                  attributes: {
                    href: item.link.url,
                    target: item.link.target ? : "_self",
                    class: "w-full"
                  }
                } %}
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
{% endif %}

{% if doc.extra %}
  {% for row in doc.extra %}
    {% set layout = row.acf_fc_layout %}
    <section class="w-full">
      {% if row.titolo or row.sottotitolo %}
        <div
          class="border-stroke flex flex-col border-b px-6 pt-20 pb-10 xl:px-10 xl:pt-30 xl:pb-20"
        >
          <div class="flex flex-col gap-6 xl:w-2/3">
            {% if row.titolo %}
              <h2 class="heading-h4 blur-in font-semibold">{{ row.titolo }}</h2>
            {% endif %}
            {% if row.sottotitolo %}
              <p class="blur-in max-w-pros text-xl text-black/80">
                {{ row.sottotitolo }}
              </p>
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% if layout == "attivita" %}
        {% if row.items %}
          {% set count = row.items|length %}
          {% set remainder_3col = count % 3 %}
          {% set filler_3col = remainder_3col > 0 ? 3 - remainder_3col : 0 %}
          {% set remainder_4col = count % 4 %}
          {% set filler_4col = remainder_4col > 0 ? 4 - remainder_4col : 0 %}
          {% set is_odd = count % 2 == 1 %}
          <div
            class="3xl:grid-cols-4 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3"
          >
            {% for item in row.items %}
              {{ include("parts/cards/attivita-card.twig") }}
            {% endfor %}
            {% if is_odd %}
              <div
                class="border-stroke col-span-1 border-b border-l xl:hidden"
              ></div>
            {% endif %}
            {% if filler_3col > 0 %}
              {% for i in 1..filler_3col %}
                <div
                  class="border-stroke 3xl:hidden col-span-1 hidden border-b xl:block {{
                  loop.first
                    ? "border-l"
                    : ""
                  }}"
                ></div>
              {% endfor %}
            {% endif %}
            {% if filler_4col > 0 %}
              {% for i in 1..filler_4col %}
                <div
                  class="border-stroke 3xl:block col-span-1 hidden border-b {{
                  loop.first
                    ? "border-l"
                    : ""
                  }}"
                ></div>
              {% endfor %}
            {% endif %}
          </div>
        {% endif %}
      {% elseif layout == "producers" %}
        {{
          include(
            "components/producers-displayer/producers-displayer.twig",
            { component: row }
          )
        }}
      {% elseif layout == "publishers" %}
        {{
          include(
            "components/publishers-displayer/publishers-displayer.twig",
            { component: row }
          )
        }}
      {% elseif layout == "text_displayer" %}
        {{
          include(
            "components/text-displayer/text-displayer.twig",
            { component: row }
          )
        }}
      {% elseif layout == "editorial_block" %}
        {{
          include(
            "components/editorial-block/editorial-block.twig",
            { component: row }
          )
        }}
      {% elseif layout == "spacer" %}
        {{ include("components/spacer/spacer.twig", { component: row }) }}
      {% elseif layout == "premi" %}
        {% if row.items %}
          {{ include("components/premi/premi.twig", { items: row.items }) }}
        {% endif %}
      {% elseif layout == "selection" %}
        {% for sel in row.items %}
          {% if sel.progetto %}
            <div class="border-stroke grid grid-cols-1 border-b xl:grid-cols-3">
              <div class="col-span-1 flex flex-col xl:col-span-2">
                {% if sel.immagine %}
                  <div
                    class="aspect-3/4 w-full overflow-hidden lg:aspect-[2/1]"
                  >
                    <img
                      src="{{ sel.immagine.url }}"
                      alt="{{ sel.immagine.alt }}"
                      class="h-full w-full object-cover"
                    />
                  </div>
                {% endif %}
                {% if sel.titolo_colonna or sel.descrizione %}
                  <div
                    class="border-stroke flex flex-col gap-6 border-b px-6 py-10 xl:border-r xl:border-b-0 xl:px-10"
                  >
                    {% if sel.titolo_colonna %}
                      <h3 class="heading-h6 font-semibold">
                        {{ sel.titolo_colonna }}
                      </h3>
                    {% endif %}
                    {% if sel.descrizione %}
                      <div class="text-xl text-black/80">
                        {{ sel.descrizione|raw }}
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
              <div class="col-span-1 flex flex-col">
                {{
                  include(
                    "parts/cards/progetti-card.twig",
                    {
                      project: sel.progetto,
                      extra_class: "h-full",
                      no_border: true,
                      inner_class: ""
                    }
                  )
                }}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        {% set items = row.items %}
        {% if items %}
          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4">
            {% set count = items|length %}
            {% set remainder_4col = count % 4 %}
            {% set filler_4col = remainder_4col > 0 ? 4 - remainder_4col : 0 %}
            {% set is_odd = count % 2 == 1 %}
            {% for item in items %}
              {% if layout == "whos_coming" %}
                {{
                  include(
                    "parts/cards/whos-coming-card.twig",
                    { person: item, extra_class: "" }
                  )
                }}
              {% else %}
                {{
                  include(
                    "parts/cards/progetti-card.twig",
                    { project: item, extra_class: "" }
                  )
                }}
              {% endif %}
            {% endfor %}
            {% if is_odd %}
              <div
                class="border-stroke col-span-1 border-b border-l xl:hidden"
              ></div>
            {% endif %}
            {% if filler_4col > 0 %}
              {% for i in 1..filler_4col %}
                <div
                  class="border-stroke col-span-1 hidden border-b xl:block {{
                  loop.first
                    ? "border-l"
                    : ""
                  }}"
                ></div>
              {% endfor %}
            {% endif %}
          </div>
        {% endif %}
      {% endif %}
    </section>
  {% endfor %}
{% endif %}
