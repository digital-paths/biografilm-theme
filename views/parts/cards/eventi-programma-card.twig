{% set id = evento.ID %}
{% set title = evento.post_title %}
{% set descrizione = function("get_field", "descrizione", id) %}
{% set link_card = function("get_field", "link_card", id) %}
{% set link = function("get_field", "link", id) %}
{% set data = function("get_field", "data", id) %}
{% set orario_inizio = function("get_field", "orario_inizio", id) %}
{% set orario_fine = function("get_field", "orario_fine", id) %}
{% set tipo_di_evento = function("wp_get_post_terms", id, "tipo-di-evento") %}
{% set location = function("wp_get_post_terms", id, "location")[0] %}
{% set sala_location = function("get_field", "sala_location", id) %}

{% set thumb_id = function("get_post_thumbnail_id", id) %}
{% set image_url = thumb_id ? function("get_the_post_thumbnail_url", id, "large") : "" %}
{% set fp = thumb_id ? function("get_post_meta", thumb_id, "focalpoint", true) : null %}
{% set fp_style = fp
  ? "object-position: " ~ ((fp.left * 100)|round) ~ "% " ~ ((fp.top * 100)|round) ~ "%;"
  : null
%}

<div
  class="border-b-stroke group relative flex flex-col border-b transition-colors duration-[1500ms] ease-in-out hover:bg-gray-200 hover:duration-700 lg:flex-row lg:items-end lg:border-b-0"
>
  {% if link_card %}
    <a
      href="{{ link_card.url }}"
      target="{{ link_card.target ?: "_self" }}"
      class="absolute inset-0 transition-colors duration-300"
      aria-label="{{ title }}"
    ></a>
  {% endif %}

  <div class="pointer-events-none relative flex min-w-0 flex-1 flex-col lg:flex-row">
    <div
      class="relative aspect-video w-full shrink-0 overflow-hidden bg-red lg:aspect-auto lg:w-65"
    >
      <div
        class="overlay absolute z-30 h-full w-full bg-transparent [mask-image:radial-gradient(ellipse_at_center,transparent_45%,black_90%)] backdrop-blur-[0px] transition-[backdrop-filter,_-webkit-backdrop-filter] duration-[1500ms] ease-in-out [-webkit-mask-image:radial-gradient(ellipse_at_center,transparent_45%,black_90%)] group-hover:backdrop-blur-[90px] group-hover:duration-700"
      ></div>
      <img
        src="{{
        image_url
          ?
          : function("get_stylesheet_directory_uri") ~ "/assets/images/fallback-img-red.jpg"
        }}"
        alt="{{ title }}"
        class="absolute inset-0 h-full w-full {{ image_url ? 'object-cover' : 'object-contain object-center lg:inset-auto lg:top-1/2 lg:left-1/2 lg:-translate-x-1/2 lg:-translate-y-1/2 lg:h-auto lg:w-full' }}"
        {{ image_url ? 'style="' ~ fp_style ~ '"' }}
      />
    </div>

    <div class="flex flex-1 flex-col justify-between gap-8 px-6 py-10 lg:border-b lg:border-b-stroke lg:px-8 lg:py-6">
      <div class="flex flex-col gap-3">
        {% if title %}
          <h5 class="text-tight text-2xl! font-semibold">{{ title }}</h5>
        {% endif %}
        {% if tipo_di_evento %}
          <p class="text-tight text-red text-sm font-semibold uppercase">
            {% for tipo in tipo_di_evento %}{{ tipo.name }}{% if not loop.last %}, {% endif %}{% endfor %}
          </p>
        {% endif %}
        {% if descrizione %}
          <p class="text-tight text-base text-black">{{ descrizione }}</p>
        {% endif %}
      </div>
      <div class="flex flex-wrap items-baseline gap-x-6 gap-y-1">
        {% if data or orario_inizio %}
          <p class="text-tight text-base font-semibold text-black">
            {% if data %}{{ data|date("d F Y") }}{% endif %}{% if orario_inizio %}{% if data %}&ensp;·&ensp;{% endif %}{{ orario_inizio }}{% if orario_fine %} – {{ orario_fine }}{% endif %}{% endif %}
          </p>
        {% endif %}
        {% if location %}
          <p class="text-tight text-base font-semibold text-black">
            {{ location.name }}{{ sala_location ? " – " ~ sala_location : "" }}
          </p>
        {% endif %}
      </div>
    </div>
  </div>

  {% if link %}
    <div class="pointer-events-auto relative z-10 lg:border-b lg:border-b-stroke">
      {{
        include(
          "components/button.twig",
          {
            as_link: true,
            label: link.title,
            variant: "default",
            size: "lg",
            attributes: {
              href: link.url,
              target: link.target ?: "_self",
              class: "text-lg! py-6 px-8 lg:w-auto w-full"
            }
          }
        )
      }}
    </div>
  {% endif %}
</div>
