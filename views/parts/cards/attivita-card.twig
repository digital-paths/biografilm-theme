{% set permalink = function("get_permalink", item.ID) %}
{% set image_url = function("get_the_post_thumbnail_url", item.ID, "large") %}
{% set thumb_id = function("get_post_thumbnail_id", item.ID) %}
{% set fp = thumb_id
  ? function("get_post_meta", thumb_id, "focalpoint", true)
  : null
%}
{% set fp_style = fp
  ? "object-position: " ~ ((fp.left * 100)|round) ~ "% "
    ~ ((fp.top * 100)|round)
    ~ "%;"
  : null
%}
{% set doc = item.post_type == "attivita-drama"
  ? function("get_field", "attivita_drama", item.ID)
  : function("get_field", "attivita_doc", item.ID)
%}

<a
  href="{{ permalink }}"
  class="group border-stroke col-span-1 flex flex-col border-b"
>
  <div class="relative aspect-video w-full overflow-hidden bg-gray-200">
    <div
      class="overlay absolute z-30 h-full w-full bg-transparent [mask-image:radial-gradient(ellipse_at_center,transparent_45%,black_90%)] backdrop-blur-[0px] transition-[backdrop-filter,_-webkit-backdrop-filter] duration-500 ease-in-out [-webkit-mask-image:radial-gradient(ellipse_at_center,transparent_45%,black_90%)] group-hover:backdrop-blur-[90px] group-hover:duration-700"
    ></div>
    <img
      src="{{
      image_url
        ?
        : site.theme.link ~ "/assets/images/fallback-img.jpg"
      }}"
      alt="{{ item.post_title }}"
      class="h-full w-full object-cover transition-all duration-500 group-hover:scale-[1.1]"
      style="{{ fp_style }}"
    />
  </div>
  <div
    class="border-l-stroke flex flex-1 flex-col gap-8 border-l px-6 py-10 md:border-l"
  >
    <div class="flex flex-1 flex-col">
      <h5 class="text-tight blur-in line-clamp-2 text-2xl font-semibold">
        {{ item.post_title }}
      </h5>
    </div>
    {% if doc.preview %}
      <p class="text-tight blur-in line-clamp-3 text-base">
        {{ doc.preview }}
      </p>
    {% endif %}
  </div>
</a>
